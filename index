w-main{height:100%;padding-top:8px}.flow-top{display:flex;justify-content:center}.flow-mid,.flow-low{display:flex;justify-content:center;gap:90px;margin-top:36px}.flow-low{gap:76px;margin-top:70px}.path-grid{display:grid;grid-template-columns:1.15fr .9fr;gap:16px;margin-top:36px}.path{border:1px solid #b7bec9;border-radius:10px;padding:13px;text-align:center;height:150px}.path-title{font-size:15px;font-weight:900;margin-bottom:9px}.path .box{font-size:12px;width:126px;padding:6px}.path .arr{font-size:24px;font-weight:900;vertical-align:middle}.small-caption{font-size:11px;color:#333;display:inline-block;width:125px}.lateral-title{text-align:center;color:#7030a0;font-size:18px;font-weight:900;margin-top:12px}.legend-box{width:300px;margin:12px auto 0;border:1px solid #c3ccd8;border-radius:8px;overflow:hidden;font-size:11px;color:#111}.legend-box .head{background:#00285f;color:#fff;padding:6px;font-weight:900;text-align:center}.legend-box .body{padding:8px 12px;line-height:1.5}.slide4-grid{display:grid;grid-template-columns:1fr 320px;gap:14px}.compact-flow .box{min-height:42px;font-size:12px}.compact-flow .flow-mid{gap:80px;margin-top:26px}.compact-flow .flow-low{gap:70px;margin-top:40px}.compact-flow .path-grid{margin-top:20px}.compact-flow .path{height:135px;padding:9px}.side-card{border:1px solid #c3ccd8;border-radius:8px;overflow:hidden;margin-bottom:8px;font-size:11.4px;color:#111}.side-card .head{background:#00285f;color:white;padding:6px;font-weight:900;text-align:center}.side-card .body{padding:8px;line-height:1.31}.training{margin-top:7px}.training th{background:#00285f!important;color:#fff!important}.training td{font-size:clamp(8.7px,.67vw,11.7px);padding:4.7px}.role-blue{background:#005aa7;color:#fff;font-weight:900}.role-yellow{background:#ffe36d;color:#111;font-weight:900}.role-lightblue{background:#b9d7f3;color:#061d3f;font-weight:900}.role-green{background:#a8d08d;color:#062b12;font-weight:900}.priority-high{text-align:center;color:var(--rojo);font-weight:900}.priority-med{text-align:center;color:var(--naranjo);font-weight:900}.footnote{text-align:center;font-size:9px;color:#333;margin-top:3px}.slide.tall{min-height:1280px}.slide4-grid{align-items:start}.slide4-grid + .training{clear:both}
@media(min-width:1200px){
  .slide.tall .training td{font-size:11.8px;line-height:1.22}
  .slide.tall .risk-table th,.slide.tall .risk-table td{font-size:12.2px;line-height:1.18;padding:6px}
}
@media(max-width:1100px){
  .slide{min-height:auto;padding:22px 18px}
  .grid2,.org-grid,.slide4-grid,.path-grid{grid-template-columns:1fr}
  .arrow{display:none}
  .goal{position:static;margin-top:20px}
}
@media(max-width:900px){.topbar{align-items:flex-start;flex-direction:column}.slide{width:98vw}.nav a{font-size:12px;padding:7px 9px}}

/* ==== AJUSTE SLIDE 4: evita desfases y cruces ==== */
#slide4{
  min-height:1500px;
  padding-top:34px;
}
#slide4 .slide4-grid{
  display:grid;
  grid-template-columns:minmax(0,1fr) 400px;
  gap:26px;
  align-items:start;
}
#slide4 .compact-flow{
  min-width:0;
  padding-top:8px;
}
#slide4 .compact-flow .flow-top{
  margin-bottom:34px;
}
#slide4 .compact-flow .flow-mid{
  display:grid;
  grid-template-columns:repeat(3, minmax(210px,1fr));
  gap:34px;
  margin-top:0;
}
#slide4 .compact-flow .flow-low{
  display:grid;
  grid-template-columns:repeat(3, minmax(180px,1fr));
  gap:42px;
  margin-top:54px;
  padding:0 34px;
}
#slide4 .compact-flow .flow-mid .box,
#slide4 .compact-flow .flow-low .box{
  width:100% !important;
  margin-right:0 !important;
}
#slide4 .compact-flow .path-grid{
  display:grid;
  grid-template-columns:1fr;
  gap:18px;
  margin-top:48px;
}
#slide4 .compact-flow .path{
  height:auto;
  min-height:152px;
  padding:18px 16px 20px;
  overflow:visible;
}
#slide4 .compact-flow .path .box{
  width:150px;
  min-height:58px;
  padding:7px 8px;
  font-size:12px;
  vertical-align:middle;
}
#slide4 .compact-flow .path .arr{
  display:inline-block;
  font-size:30px;
  width:34px;
  text-align:center;
  vertical-align:middle;
}
#slide4 .compact-flow .small-caption{
  width:150px;
  font-size:12px;
  line-height:1.18;
  margin-top:8px;
}
#slide4 .lateral-title{
  margin-top:24px !important;
  margin-bottom:10px;
  clear:both;
}
#slide4 .lateral-title + .center{
  display:flex;
  justify-content:center;
  align-items:center;
  gap:70px;
  margin-top:0 !important;
}
#slide4 .lateral-title + .center .box{
  margin-right:0 !important;
}
#slide4 aside{
  min-width:0;
}
#slide4 .side-card{
  font-size:14px;
  margin-bottom:14px;
}
#slide4 .side-card .head{
  font-size:15px;
  padding:10px;
}
#slide4 .side-card .body{
  padding:13px 14px;
  line-height:1.42;
}
#slide4 .training{
  margin-top:30px;
}
#slide4 .training th{
  font-size:13px;
  padding:10px 8px;
}
#slide4 .training td{
  font-size:12.2px;
  line-height:1.26;
  padding:8px 9px;
}
@media(max-width:1300px){
  #slide4 .slide4-grid{grid-template-columns:1fr;}
  #slide4 aside{display:grid;grid-template-columns:repeat(3,1fr);gap:12px;}
}
@media(max-width:900px){
  #slide4 aside{display:block;}
  #slide4 .compact-flow .flow-mid,
  #slide4 .compact-flow .flow-low{grid-template-columns:1fr;padding:0;}
  #slide4 .compact-flow .path .arr{display:block;margin:6px auto;}
  #slide4 .lateral-title + .center{flex-direction:column;gap:12px;}
}



/* ==== TOOLTIP FUNCIONES POR CARGO ==== */
.role-tooltip{
  position:fixed;
  z-index:9999;
  width:min(430px, calc(100vw - 32px));
  background:#ffffff;
  color:#0b234f;
  border:1px solid #c9d5e6;
  border-top:6px solid #002b68;
  border-radius:16px;
  box-shadow:0 18px 45px rgba(0,43,104,.24);
  padding:14px 16px 16px;
  opacity:0;
  transform:translateY(8px);
  pointer-events:none;
  transition:opacity .16s ease, transform .16s ease;
  font-size:13px;
  line-height:1.28;
}
.role-tooltip.visible{opacity:1;transform:translateY(0)}
.role-tooltip h3{
  margin:0 0 8px;
  font-size:15px;
  font-weight:900;
  color:#002b68;
}
.role-tooltip table{width:100%;border-collapse:collapse}
.role-tooltip th,.role-tooltip td{border:1px solid #d8e0ec;padding:6px;vertical-align:top}
.role-tooltip th{background:#f0f5fb;color:#002b68;text-align:left;font-size:12px}
.role-tooltip td:first-child{font-weight:800;width:45%}
.has-role-tooltip{cursor:help;position:relative;outline-offset:3px}
.has-role-tooltip:hover{filter:brightness(1.03);box-shadow:0 8px 22px rgba(0,43,104,.18)}
@media(max-width:900px){.role-tooltip{font-size:12px;width:calc(100vw - 24px)}}



/* ==== VERSIÓN CUADRADA SLIDE 4 + BOTÓN OCULTAR INFORMACIÓN ==== */
.slide-head-row{
  display:flex;
  align-items:center;
  justify-content:space-between;
  gap:18px;
  margin-bottom:24px;
}
.info-toggle{
  border:1px solid #c8d8ea;
  background:#eef5fd;
  color:#002b68;
  border-radius:999px;
  padding:11px 18px;
  font-weight:900;
  font-size:14px;
  cursor:pointer;
  box-shadow:0 6px 18px rgba(0,43,104,.10);
  white-space:nowrap;
}
.info-toggle:hover{background:#002b68;color:#fff}
#slide4{
  min-height:1180px;
  padding:34px 42px 54px;
}
#slide4 .fixed-layout{
  display:grid;
  grid-template-columns:minmax(980px,1fr) 360px;
  gap:26px;
  align-items:start;
}
#slide4 .flow-board{
  border:1px solid #d8e0ec;
  border-radius:18px;
  background:#fbfdff;
  padding:28px 30px 30px;
  min-width:0;
}
#slide4 .flow-level{display:flex;justify-content:center;align-items:center}
#slide4 .top-level{margin-bottom:38px}
#slide4 .three-cols{
  display:grid;
  grid-template-columns:repeat(3, minmax(0,1fr));
  gap:42px;
  margin-bottom:58px;
}
#slide4 .three-cols.operators{margin-bottom:0;padding:0 88px;gap:64px}
#slide4 .three-cols .box{
  width:100%;
  min-height:84px;
  font-size:18px;
  border-radius:14px;
}
#slide4 .operators .box{min-height:72px;font-size:17px}
#slide4 .clean-paths{
  display:grid;
  grid-template-columns:1fr 1fr;
  gap:24px;
  margin-top:34px;
}
#slide4 .clean-path{
  height:auto;
  min-height:205px;
  padding:18px;
  background:#fff;
  border:1px solid #b7c4d6;
  border-radius:16px;
  overflow:visible;
}
#slide4 .path-title{
  text-align:center;
  font-size:18px;
  margin-bottom:18px;
}
#slide4 .path-steps{
  display:grid;
  align-items:start;
  gap:10px;
}
#slide4 .path-steps.four{grid-template-columns:1fr 34px 1fr 34px 1fr 34px 1fr}
#slide4 .path-steps.three{grid-template-columns:1fr 34px 1fr 34px 1fr}
#slide4 .step{display:flex;flex-direction:column;align-items:center;gap:9px;min-width:0}
#slide4 .step .box{
  width:100%;
  min-height:62px;
  font-size:13px;
  padding:8px;
  border-radius:13px;
}
#slide4 .step small{
  display:block;
  font-size:12px;
  line-height:1.16;
  color:#222;
  text-align:center;
}
#slide4 .arrow-step{
  display:flex;
  justify-content:center;
  align-items:center;
  height:62px;
  font-size:30px;
  font-weight:900;
  color:#063579;
}
#slide4 .green-arr{color:#397b22}
#slide4 .lateral-card{
  margin-top:24px;
  border:1px dashed #c7b4dd;
  background:#fbf8ff;
  border-radius:16px;
  padding:16px 18px 20px;
}
#slide4 .lateral-title{
  margin:0 0 14px!important;
  font-size:22px;
}
#slide4 .lateral-boxes{
  display:grid;
  grid-template-columns:1fr 60px 1fr;
  gap:18px;
  align-items:center;
}
#slide4 .lateral-boxes .box{width:100%;min-height:72px;font-size:16px}
#slide4 .side-arrow{font-size:34px;font-weight:900;color:#7030a0;text-align:center}
#slide4 .info-side{display:flex;flex-direction:column;gap:14px}
#slide4 .side-card{margin:0;font-size:14px;border-radius:14px;box-shadow:0 8px 24px rgba(0,43,104,.07)}
#slide4 .side-card .head{font-size:15px;padding:11px 12px}
#slide4 .side-card .body{padding:14px 15px;line-height:1.43}
#slide4 .training-wrap{margin-top:28px}
#slide4 .training th{font-size:13.5px;padding:11px 10px}
#slide4 .training td{font-size:12.4px;line-height:1.28;padding:9px 10px}
#slide4.hide-info .info-content{display:none!important}
#slide4.hide-info .fixed-layout{grid-template-columns:1fr;max-width:1320px;margin:0 auto}
#slide4.hide-info .flow-board{padding:34px 42px 40px}
#slide4.hide-info .info-toggle{background:#002b68;color:#fff}
@media(max-width:1450px){
  #slide4 .fixed-layout{grid-template-columns:1fr}
  #slide4 .info-side{display:grid;grid-template-columns:repeat(3,1fr)}
}
@media(max-width:1050px){
  .slide-head-row{flex-direction:column;align-items:flex-start}
  #slide4{padding:26px 18px}
  #slide4 .three-cols,#slide4 .three-cols.operators,#slide4 .clean-paths,#slide4 .info-side{grid-template-columns:1fr;padding:0;gap:16px;margin-bottom:22px}
  #slide4 .path-steps.four,#slide4 .path-steps.three{grid-template-columns:1fr}
  #slide4 .arrow-step{height:auto;transform:rotate(90deg)}
  #slide4 .lateral-boxes{grid-template-columns:1fr}
}


/* ==== AJUSTE SLIDE 2: estructura más compacta y sin desborde ==== */
#slide2{
  min-height:980px;
  padding:26px 30px 42px;
  overflow:visible;
}
#slide2 .main-title{
  font-size:clamp(22px,1.75vw,31px);
  margin-bottom:16px;
}
#slide2 .org-grid{
  grid-template-columns:minmax(0,1fr) 34px minmax(0,1fr);
  gap:12px;
  height:auto;
  align-items:stretch;
}
#slide2 .org-grid > div:not(.arrow){
  min-width:0;
  border:1px solid #d8e0ec;
  border-radius:16px;
  padding:16px 14px 14px;
  background:#fbfdff;
}
#slide2 .section-title,#slide2 .green-title{
  font-size:clamp(16px,1.25vw,22px);
  padding:8px 10px;
  margin-bottom:14px;
}
#slide2 .center{margin-top:20px!important}
#slide2 .center .box{
  width:min(300px,100%)!important;
  font-size:clamp(13px,1vw,16px)!important;
  min-height:66px;
}
#slide2 .org-row,#slide2 .org-row.tight{
  display:grid;
  grid-template-columns:repeat(auto-fit,minmax(128px,1fr));
  gap:10px;
  margin-top:24px!important;
  width:100%;
}
#slide2 .org-row .box{
  width:100%!important;
  min-height:74px;
  font-size:clamp(11px,.78vw,13px)!important;
  padding:8px 7px;
  line-height:1.12;
}
#slide2 .note{
  margin-top:24px!important;
  padding:10px 12px;
  font-size:clamp(11.5px,.85vw,14px);
  line-height:1.2;
}
#slide2 .note .card-title{font-size:clamp(13px,1vw,16px);margin-bottom:6px}
#slide2 .note ul{margin:6px 0 0 16px}
#slide2 .arrow{
  font-size:42px;
  display:flex;
  align-items:center;
  justify-content:center;
}
#slide2 .goal{margin-top:18px}
#slide2 .goal table{font-size:clamp(11.5px,.9vw,15px)}
#slide2 .goal td{padding:10px 8px}
#slide2 .goal td:first-child{width:190px}
@media(max-width:1350px){
  #slide2 .org-grid{grid-template-columns:1fr;gap:14px}
  #slide2 .arrow{display:none}
  #slide2 .goal table,#slide2 .goal tbody,#slide2 .goal tr,#slide2 .goal td{display:block;width:100%!important}
  #slide2 .goal td{border-bottom:1px solid #e2e8f0}
}

</style>
</head>
<body>
<header class="topbar">
  <div class="brand">Presentación Optimización Operacional</div>
  <nav class="nav">
    <a href="#slide1">Costos y riesgos</a>
    <a href="#slide2">Estructura</a>
    <a href="#slide3">Movilidad</a>
    <a href="#slide4">Capacitación</a>
  </nav>
</header>
<main class="deck">
<section class="slide tall" id="slide1" data-slide="Slide 1 / 4">
  <div class="grid2">
    <div class="panel">
      <h2 class="section-title">COMPARACIÓN DE COSTOS</h2>
