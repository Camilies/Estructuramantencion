  let y = ev.clientY + 18;
  if(x + rect.width + pad > window.innerWidth) x = ev.clientX - rect.width - 18;
  if(y + rect.height + pad > window.innerHeight) y = window.innerHeight - rect.height - pad;
  if(y < pad) y = pad;
  tooltip.style.left = x + 'px';
  tooltip.style.top = y + 'px';
}
document.querySelectorAll('.box, .training td:first-child').forEach(el => {
  const key = detectRole(el);
  if(!key || !roleFunctions[key]) return;
  el.classList.add('has-role-tooltip');
  el.addEventListener('mouseenter', ev => {
    const data = roleFunctions[key];
    tooltip.innerHTML = tooltipHTML(data);
    tooltip.style.borderTopColor = data.color;
    tooltip.classList.add('visible');
    positionTooltip(ev);
  });
  el.addEventListener('mousemove', positionTooltip);
  el.addEventListener('mouseleave', () => tooltip.classList.remove('visible'));
});


const slide4 = document.getElementById('slide4');
const infoToggle = slide4 ? slide4.querySelector('.info-toggle') : null;
if(infoToggle){
  infoToggle.addEventListener('click', () => {
    const hidden = slide4.classList.toggle('hide-info');
    infoToggle.setAttribute('aria-pressed', hidden ? 'true' : 'false');
    infoToggle.textContent = hidden ? 'Mostrar información complementaria' : 'Ocultar información complementaria';
  });
}

</script>

